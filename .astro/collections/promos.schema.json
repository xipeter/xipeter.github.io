{
  "$ref": "#/definitions/promos",
  "definitions": {
    "promos": {
      "type": "object",
      "properties": {
        "brand": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "referral",
            "discount",
            "trial",
            "bundle"
          ]
        },
        "region": {
          "type": "string"
        },
        "eligibility": {
          "type": "string"
        },
        "rewardSummary": {
          "type": "string"
        },
        "lastVerified": {
          "type": "string"
        },
        "stepsToRedeem": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "disclosure": {
          "type": "string"
        },
        "faq": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "question": {
                "type": "string"
              },
              "answer": {
                "type": "string"
              }
            },
            "required": [
              "question",
              "answer"
            ],
            "additionalProperties": false
          }
        },
        "alternatives": {
          "type": "array",
