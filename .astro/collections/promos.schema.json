            "required": [
              "brand",
              "offer",
              "url"
            ],
            "additionalProperties": false
          }
        },
        "seo": {
          "type": "object",
          "properties": {
            "title": {
              "type": "string"
            },
            "description": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "adEligible": {
          "type": "boolean",
          "default": true
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "brand",
        "type",
        "region",
        "eligibility",
        "rewardSummary",
        "lastVerified",
        "stepsToRedeem",
        "disclosure"
      ],
      "additionalProperties": false
    }
