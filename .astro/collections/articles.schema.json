{
  "$ref": "#/definitions/articles",
  "definitions": {
    "articles": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "excerpt": {
          "type": "string"
        },
        "category": {
          "type": "string",
          "enum": [
            "tutorial",
            "guide",
            "reference",
            "opinion",
            "news-analysis"
          ]
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "publishedAt": {
          "type": "string"
        },
        "updatedAt": {
          "type": "string"
        },
        "author": {
          "type": "string",
          "default": "xipeter"
        },
        "readingTime": {
          "type": "string"
        },
        "hero": {
          "type": "string"
        },
        "faq": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "question": {
                "type": "string"
              },
              "answer": {
                "type": "string"
              }
            },
            "required": [
              "question",
              "answer"
            ],
            "additionalProperties": false
          }
        },
        "relatedTools": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "seo": {
          "type": "object",
          "properties": {
            "title": {
              "type": "string"
            },
            "description": {
              "type": "string"
            },
            "keywords": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false
        },
        "adEligible": {
          "type": "boolean",
          "default": true
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "excerpt",
        "category",
        "tags",
        "publishedAt",
        "readingTime"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}