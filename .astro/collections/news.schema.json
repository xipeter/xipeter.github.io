          "additionalProperties": false
        },
        "adEligible": {
          "type": "boolean",
          "default": true
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "topic",
        "sourceName",
        "sourceUrl",
        "sourcePublishedAt",
        "reviewedAt",
        "summary",
        "whyItMatters"
