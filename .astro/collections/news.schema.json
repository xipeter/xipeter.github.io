{
  "$ref": "#/definitions/news",
  "definitions": {
    "news": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "topic": {
          "type": "string",
          "enum": [
            "ai",
            "cloud",
            "dev-tools",
            "security",
            "telecom",
            "web",
            "mobile",
            "hardware",
            "other"
          ]
        },
        "sourceName": {
          "type": "string"
        },
        "sourceUrl": {
          "type": "string"
        },
        "sourcePublishedAt": {
          "type": "string"
        },
        "reviewedAt": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "whyItMatters": {
          "type": "string"
        },
        "relatedLinks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": {
                "type": "string"
              },
              "url": {
                "type": "string"
              }
