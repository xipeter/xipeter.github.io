---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const promos = await getCollection('promos');
  return promos.map(promo => ({
    params: { slug: promo.slug },
    props: { promo }
  }));
}

const { promo } = Astro.props;
const { Content } = await promo.render();
---

<MainLayout 
  title={promo.data.seo?.title || `${promo.data.brand} ${promo.data.type}`} 
  description={promo.data.seo?.description || promo.data.rewardSummary}
  pageType="promo"
>
  <article class="promo-page">
    <header class="promo-header">
      <div class="meta">
        <span class="type-tag">{promo.data.type}</span>
        <span class="region">{promo.data.region}</span>
      </div>
      <h1>{promo.data.brand} {promo.data.type === 'referral' ? 'Referral' : promo.data.type}</h1>
      <p class="reward">{promo.data.rewardSummary}</p>
    </header>

    <section class="promo-content">
      <Content />
    </section>

    <aside class="promo-sidebar">
      <div class="info-box">
        <h3>Quick Info</h3>
        <dl>
          <dt>Region</dt>
          <dd>{promo.data.region}</dd>
          <dt>Eligibility</dt>
          <dd>{promo.data.eligibility}</dd>
          <dt>Last Verified</dt>
          <dd>{promo.data.lastVerified}</dd>
        </dl>
      </div>

      <div class="steps-box">
        <h3>Steps to Redeem</h3>
        <ol>
          {promo.data.stepsToRedeem.map(step => (
            <li>{step}</li>
          ))}
        </ol>
      </div>

      {promo.data.faq && promo.data.faq.length > 0 && (
        <div class="faq-box">
          <h3>FAQ</h3>
          {promo.data.faq.map(faq => (
            <div class="faq-item">
              <strong>{faq.question}</strong>
              <p>{faq.answer}</p>
            </div>
          ))}
        </div>
      )}

      {promo.data.alternatives && promo.data.alternatives.length > 0 && (
        <div class="alternatives-box">
          <h3>Alternatives</h3>
          <ul>
            {promo.data.alternatives.map(alt => (
              <li>
                <strong>{alt.brand}</strong>
                <p>{alt.offer}</p>
              </li>
            ))}
          </ul>
        </div>
      )}

      <div class="disclosure-box">
        <h3>Disclosure</h3>
        <p>{promo.data.disclosure}</p>
      </div>
    </aside>
  </article>
</MainLayout>

<style>
  .promo-page {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: var(--spacing-xl);
  }

  .promo-header {
    grid-column: 1 / -1;
    margin-bottom: var(--spacing-xl);
    padding-bottom: var(--spacing-lg);
    border-bottom: 1px solid var(--border);
  }

  .meta {
    display: flex;
    gap: var(--spacing-md);
    align-items: center;
    margin-bottom: var(--spacing-md);
  }

  .type-tag {
    background: var(--primary);
    color: white;
    padding: 4px 12px;
    border-radius: 4px;
    font-size: 0.875rem;
    text-transform: capitalize;
  }

  .region {
    color: var(--text-secondary);
    font-size: 0.875rem;
  }

  .promo-header h1 {
    font-size: 2rem;
    margin-bottom: var(--spacing-md);
  }

  .reward {
    font-size: 1.125rem;
    color: var(--primary);
    font-weight: 500;
  }

  .promo-content {
    min-width: 0;
  }

  .promo-content :global(h2) {
    font-size: 1.5rem;
    margin-top: var(--spacing-xl);
    margin-bottom: var(--spacing-md);
    color: var(--primary);
  }

  .promo-content :global(h3) {
    font-size: 1.25rem;
    margin-top: var(--spacing-lg);
    margin-bottom: var(--spacing-sm);
  }

  .promo-content :global(p) {
    line-height: 1.7;
    margin-bottom: var(--spacing-md);
  }

  .promo-content :global(ul), .promo-content :global(ol) {
    padding-left: var(--spacing-lg);
    margin-bottom: var(--spacing-md);
  }

  .promo-content :global(li) {
    margin-bottom: var(--spacing-sm);
  }

  .promo-sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
  }

  .info-box, .steps-box, .faq-box, .alternatives-box, .disclosure-box {
    background: var(--bg-secondary);
    padding: var(--spacing-lg);
    border-radius: 8px;
  }

  .info-box h3, .steps-box h3, .faq-box h3, .alternatives-box h3, .disclosure-box h3 {
    font-size: 1rem;
    margin-bottom: var(--spacing-md);
    color: var(--primary);
  }

  .info-box dl {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--spacing-sm) var(--spacing-md);
    font-size: 0.875rem;
  }

  .info-box dt {
    font-weight: 600;
    color: var(--text-secondary);
  }

  .info-box dd {
    margin: 0;
  }

  .steps-box ol {
    padding-left: var(--spacing-lg);
    margin: 0;
    font-size: 0.875rem;
  }

  .steps-box li {
    margin-bottom: var(--spacing-sm);
  }

  .faq-item {
    margin-bottom: var(--spacing-md);
    font-size: 0.875rem;
  }

  .faq-item strong {
    display: block;
    margin-bottom: var(--spacing-sm);
  }

  .faq-item p {
    color: var(--text-secondary);
    margin: 0;
  }

  .alternatives-box ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .alternatives-box li {
    margin-bottom: var(--spacing-md);
  }

  .alternatives-box strong {
    display: block;
  }

  .alternatives-box p {
    margin: 0;
    font-size: 0.875rem;
    color: var(--text-secondary);
  }

  .disclosure-box p {
    font-size: 0.75rem;
    color: var(--text-secondary);
    margin: 0;
    line-height: 1.5;
  }

  @media (max-width: 900px) {
    .promo-page {
      grid-template-columns: 1fr;
    }

    .promo-sidebar {
      order: -1;
    }
  }
</style>
