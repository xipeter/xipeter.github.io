---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map(article => ({
    params: { slug: article.slug },
    props: { article }
  }));
}

const { article } = Astro.props;
const { Content } = await article.render();
---

<MainLayout 
  title={article.data.seo?.title || article.data.title} 
  description={article.data.seo?.description || article.data.excerpt}
  pageType="article"
>
  <article class="article-page">
    <header class="article-header">
      <div class="meta">
        <span class="category-tag">{article.data.category}</span>
        <span class="reading-time">{article.data.readingTime}</span>
        <span class="date">{article.data.publishedAt}</span>
      </div>
      <h1>{article.data.title}</h1>
      <p class="excerpt">{article.data.excerpt}</p>
      <div class="tags">
        {article.data.tags.map(tag => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    </header>

    <section class="article-content">
      <Content />
    </section>

    {article.data.faq && article.data.faq.length > 0 && (
      <aside class="article-sidebar">
        <div class="faq-box">
          <h3>FAQ</h3>
          {article.data.faq.map(faq => (
            <div class="faq-item">
              <strong>{faq.question}</strong>
              <p>{faq.answer}</p>
            </div>
          ))}
        </div>
      </aside>
    )}
  </article>
</MainLayout>

<style>
  .article-page {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: var(--spacing-xl);
  }

  .article-header {
    grid-column: 1 / -1;
    margin-bottom: var(--spacing-xl);
    padding-bottom: var(--spacing-lg);
    border-bottom: 1px solid var(--border);
  }

  .meta {
    display: flex;
    gap: var(--spacing-md);
    align-items: center;
    margin-bottom: var(--spacing-md);
    font-size: 0.875rem;
    color: var(--text-secondary);
  }

  .category-tag {
    background: var(--primary);
    color: white;
    padding: 4px 12px;
    border-radius: 4px;
  }

  .article-header h1 {
    font-size: 2rem;
    margin-bottom: var(--spacing-md);
  }

  .excerpt {
    font-size: 1.125rem;
    color: var(--text-secondary);
    margin-bottom: var(--spacing-md);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
  }

  .tag {
    background: var(--bg-secondary);
    padding: 4px 10px;
    border-radius: 4px;
    font-size: 0.75rem;
    color: var(--text-secondary);
  }

  .article-content {
    min-width: 0;
  }

  .article-content :global(h2) {
    font-size: 1.5rem;
    margin-top: var(--spacing-xl);
    margin-bottom: var(--spacing-md);
    color: var(--primary);
  }

  .article-content :global(h3) {
    font-size: 1.25rem;
    margin-top: var(--spacing-lg);
    margin-bottom: var(--spacing-sm);
  }

  .article-content :global(p) {
    line-height: 1.7;
    margin-bottom: var(--spacing-md);
  }

  .article-content :global(ul), .article-content :global(ol) {
    padding-left: var(--spacing-lg);
    margin-bottom: var(--spacing-md);
  }

  .article-content :global(li) {
    margin-bottom: var(--spacing-sm);
  }

  .article-content :global(pre) {
    background: var(--bg-secondary);
    padding: var(--spacing-md);
    border-radius: 8px;
    overflow-x: auto;
    margin-bottom: var(--spacing-md);
  }

  .article-content :global(code) {
    font-family: monospace;
    background: var(--bg-secondary);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.875em;
  }

  .article-content :global(pre code) {
    padding: 0;
    background: none;
  }

  .article-sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
  }

  .faq-box {
    background: var(--bg-secondary);
    padding: var(--spacing-lg);
    border-radius: 8px;
  }

  .faq-box h3 {
    font-size: 1rem;
    margin-bottom: var(--spacing-md);
    color: var(--primary);
  }

  .faq-item {
    margin-bottom: var(--spacing-md);
    font-size: 0.875rem;
  }

  .faq-item strong {
    display: block;
    margin-bottom: var(--spacing-sm);
  }

  .faq-item p {
    color: var(--text-secondary);
    margin: 0;
  }

  @media (max-width: 900px) {
    .article-page {
      grid-template-columns: 1fr;
    }

    .article-sidebar {
      order: -1;
    }
  }
</style>
