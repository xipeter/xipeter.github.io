---
import MainLayout from '../../layouts/MainLayout.astro';
import { getTranslations } from '../../i18n/index';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'zh' } }
  ];
}

const { lang } = Astro.params;
const t = getTranslations(lang);
---

<MainLayout
  title={t.affiliate.title}
  description={t.affiliate.intro}
  pageType="affiliate-disclosure"
  showAds={false}
  locale={lang}
>
  <article class="policy-page">
    <h1>{t.affiliate.title}</h1>

    <section>
      <p>{t.affiliate.intro}</p>
    </section>

    <section>
      <p>{t.affiliate.transparency}</p>
    </section>

    <section>
      <p>{t.affiliate.noCost}</p>
    </section>
  </article>
</MainLayout>

<style>
  .policy-page { max-width: 800px; margin: 0 auto; }
  h1 { margin-bottom: var(--spacing-xl); }
  section { margin-bottom: var(--spacing-xl); }
  section p { color: var(--text-secondary); line-height: 1.7; }
</style>
