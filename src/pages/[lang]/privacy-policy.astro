---
import MainLayout from '../../layouts/MainLayout.astro';
import { getTranslations } from '../../i18n/index';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'zh' } }
  ];
}

const { lang } = Astro.params;
const t = getTranslations(lang);
---

<MainLayout
  title={t.privacy.title}
  description={t.privacy.intro}
  pageType="privacy-policy"
  showAds={false}
  locale={lang}
>
  <article class="policy-page">
    <h1>{t.privacy.title}</h1>
    <p class="last-updated">{t.privacy.lastUpdated}</p>

    <section>
      <h2>{t.privacy.collectTitle}</h2>
      <p>{t.privacy.collectIntro}</p>
      <ul>
        <li><strong>{t.privacy.collectProvide}:</strong> {t.privacy.collectProvideText}</li>
        <li><strong>{t.privacy.collectAuto}:</strong> {t.privacy.collectAutoText}</li>
      </ul>
    </section>

    <section>
      <h2>{t.privacy.cookiesTitle}</h2>
      <p>{t.privacy.cookiesText}</p>
    </section>

    <section>
      <h2>{t.privacy.thirdPartyTitle}</h2>
      <p>{t.privacy.thirdPartyText}</p>
    </section>

    <section>
      <h2>{t.privacy.contactTitle}</h2>
      <p>{t.privacy.contactText}</p>
    </section>
  </article>
</MainLayout>

<style>
  .policy-page { max-width: 800px; margin: 0 auto; }
  h1 { margin-bottom: var(--spacing-sm); }
  .last-updated { color: var(--text-secondary); margin-bottom: var(--spacing-xl); }
  section { margin-bottom: var(--spacing-xl); }
  section h2 { font-size: 1.5rem; margin-bottom: var(--spacing-md); }
  section p { color: var(--text-secondary); line-height: 1.7; }
  ul { list-style: disc; margin-left: var(--spacing-lg); color: var(--text-secondary); }
  li { margin-bottom: var(--spacing-sm); line-height: 1.7; }
</style>
