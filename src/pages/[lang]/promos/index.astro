---
import MainLayout from '../../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
import { getTranslations, getLocalizedPath } from '../../../i18n/index';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'zh' } }
  ];
}

const { lang } = Astro.params;
const t = getTranslations(lang);

const promos = await getCollection('promos');
const sortedPromos = promos.sort((a, b) => b.data.lastVerified.localeCompare(a.data.lastVerified));

const hubTitle = lang === 'en'
  ? 'Deals & Referral Offers — Verified and Updated'
  : '优惠与推荐活动 — 已验证并持续更新';
const hubDescription = lang === 'en'
  ? 'Save money with verified referral deals and discount offers. Each deal is tested, verified, and updated regularly.'
  : '通过经过验证的推荐优惠和折扣活动省钱。每项优惠都经过测试、验证并定期更新。';
---

<MainLayout
  title={hubTitle}
  description={hubDescription}
  pageType="promos"
  showAds={false}
  locale={lang}
>
  <h1>{hubTitle}</h1>
  <p class="intro">{t.promos.subtitle}</p>

  <div class="promos-grid">
    {sortedPromos.map(promo => {
      const isXfinity = promo.slug === 'xfinity-referral';
      const cardTitle = isXfinity
        ? (lang === 'en' ? 'Get $50 Off Xfinity Internet + $50/Line Mobile' : '获得 $50 Xfinity 互联网折扣 + 每线路 $50 移动折扣')
        : promo.data.brand;
      return (
        <a href={getLocalizedPath(`/promos/${promo.slug}`, lang)} class="promo-card">
          <div class="card-top">
            <span class="brand-badge">{promo.data.brand}</span>
            <span class="verified-badge">{t.promos.verifiedLabel} {promo.data.lastVerified}</span>
          </div>
          <h2>{cardTitle}</h2>
          <p class="reward">{promo.data.rewardSummary}</p>
          <p class="eligibility">{promo.data.eligibility}</p>
          <span class="card-cta">{lang === 'en' ? 'View deal' : '查看优惠'} &rarr;</span>
        </a>
      );
    })}
    {sortedPromos.length === 0 && (
      <div class="empty-state">
        <p>{t.promos.noPromos}</p>
      </div>
    )}
  </div>
</MainLayout>

<style>
  h1 { margin-bottom: var(--spacing-sm); }
  .intro { color: var(--text-secondary); margin-bottom: var(--spacing-xl); font-size: 1.125rem; }
  .promos-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: var(--spacing-lg); }
  .promo-card { display: flex; flex-direction: column; padding: var(--spacing-lg); background: var(--bg); border: 1px solid var(--border); border-radius: 12px; text-decoration: none; color: inherit; transition: border-color 0.2s, box-shadow 0.2s; }
  .promo-card:hover { border-color: var(--primary); box-shadow: 0 4px 16px rgba(0,0,0,0.1); text-decoration: none; }
  .card-top { display: flex; align-items: center; gap: var(--spacing-sm); margin-bottom: var(--spacing-md); flex-wrap: wrap; }
  .brand-badge { display: inline-block; background: var(--primary); color: white; padding: 4px 12px; border-radius: 4px; font-size: 0.8125rem; font-weight: 600; }
  .verified-badge { display: inline-block; background: #e8f5e9; color: #2e7d32; padding: 4px 10px; border-radius: 4px; font-size: 0.75rem; font-weight: 600; }
  .promo-card h2 { font-size: 1.25rem; margin-bottom: var(--spacing-sm); line-height: 1.3; }
  .reward { font-weight: 600; color: var(--primary); font-size: 1.0625rem; margin-bottom: var(--spacing-md); }
  .eligibility { font-size: 0.875rem; color: var(--text-secondary); line-height: 1.5; flex: 1; }
  .card-cta { display: inline-block; margin-top: var(--spacing-md); color: var(--primary); font-weight: 600; font-size: 0.875rem; }
  .empty-state { grid-column: 1 / -1; text-align: center; padding: var(--spacing-xl); color: var(--text-secondary); }
</style>
