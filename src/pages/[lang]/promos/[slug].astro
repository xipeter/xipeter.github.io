---
import MainLayout from '../../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
import { getTranslations, getLocalizedPath } from '../../../i18n/index';

export async function getStaticPaths() {
  const promos = await getCollection('promos');
  const locales = ['en', 'zh'];

  const paths = [];
  for (const promo of promos) {
    for (const locale of locales) {
      paths.push({ params: { lang: locale, slug: promo.slug }, props: { promo } });
    }
  }
  return paths;
}

const { lang, slug } = Astro.params;
const { promo } = Astro.props;
const t = getTranslations(lang);
const { Content } = await promo.render();

const isXfinity = slug === 'xfinity-referral';
const referralLink = 'https://referafriend.xfinity.com/ZONGFEI!cbb4bae738!a';

const zhSteps: Record<number, string> = {
  0: '查看并接受推荐计划条款和条件',
  1: '从您的 Xfinity 仪表板分享您的推荐链接',
  2: '朋友有 30 天时间接受邀请并添加符合条件的服务',
  3: '双方必须保持良好信誉 90 天',
  4: '符合资格后 4-6 周内通过电子邮件发送奖励'
};

function getStepText(step: string, index: number): string {
  if (lang === 'en') return step;
  return zhSteps[index] || step;
}

const pageTitle = isXfinity
  ? (lang === 'en' ? 'Xfinity Referral Program' : 'Xfinity 推荐计划')
  : promo.data.brand;
---

<MainLayout
  title={pageTitle}
  description={promo.data.seo?.description || promo.data.eligibility}
  pageType="promo"
  locale={lang}
>
  <article class="promo-page">
    <a href={getLocalizedPath('/promos', lang)} class="back-link">&larr; {t.promos.backToHub}</a>

    <header class="promo-header">
      <span class="brand-badge">{promo.data.brand}</span>
      <h1>{pageTitle}</h1>

      <div class="reward-box">
        <span class="label">{t.promos.rewardLabel}:</span>
        <span class="value">{promo.data.rewardSummary}</span>
      </div>

      <div class="meta">
        <span class="region">{promo.data.region === 'United States' ? t.promos.regionUS : promo.data.region}</span>
        <span class="verified">{t.promos.verifiedLabel}: {promo.data.lastVerified}</span>
      </div>
    </header>

    {isXfinity && (
      <section class="referral-cta">
        <h2>{t.promos.referralCtaTitle}</h2>
        <p>{t.promos.referralCtaText}</p>
        <a href={referralLink} class="cta-button" target="_blank" rel="noopener noreferrer">
          {t.promos.referralCtaButton}
        </a>
        <p class="cta-note">{t.promos.referralCtaNote}</p>
      </section>
    )}

    <section class="eligibility">
      <h2>{t.promos.eligibilityTitle}</h2>
      <p>{promo.data.eligibility}</p>
    </section>

    <section class="how-it-works">
      <h2>{t.promos.howItWorksTitle}</h2>
      <ol>
        {(promo.data.stepsToRedeem || []).map((step: string, i: number) => (
          <li>{getStepText(step, i)}</li>
        ))}
      </ol>
    </section>

    <div class="content-body">
      <Content />
    </div>

    {promo.data.faq && promo.data.faq.length > 0 && (
      <section class="faq">
        <h2>FAQ</h2>
        {promo.data.faq.map(item => (
          <div class="faq-item">
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </div>
        ))}
      </section>
    )}

    <section class="disclosure">
      <h3>{t.promos.disclosureLabel}</h3>
      <p>{t.promos.disclosureText}</p>
    </section>
  </article>
</MainLayout>

<style>
  .promo-page { max-width: 800px; margin: 0 auto; }
  .back-link { display: inline-block; margin-bottom: var(--spacing-md); color: var(--primary); }

  .promo-header { margin-bottom: var(--spacing-xl); }
  .brand-badge { display: inline-block; background: var(--primary); color: white; padding: 4px 12px; border-radius: 4px; font-size: 0.875rem; font-weight: 600; margin-bottom: var(--spacing-sm); }
  .promo-header h1 { margin-bottom: var(--spacing-lg); }
  .reward-box { background: var(--bg-secondary); padding: var(--spacing-lg); border-radius: 8px; margin-bottom: var(--spacing-lg); }
  .reward-box .label { color: var(--text-secondary); margin-right: var(--spacing-sm); }
  .reward-box .value { font-weight: 600; color: var(--primary); font-size: 1.125rem; }
  .meta { display: flex; gap: var(--spacing-md); font-size: 0.875rem; color: var(--text-secondary); }

  .referral-cta { background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%); color: white; padding: var(--spacing-xl); border-radius: 12px; margin-bottom: var(--spacing-xl); text-align: center; }
  .referral-cta h2 { color: white; margin-bottom: var(--spacing-md); font-size: 1.5rem; }
  .referral-cta p { color: rgba(255,255,255,0.9); margin-bottom: var(--spacing-lg); line-height: 1.6; }
  .cta-button { display: inline-block; background: #e1402a; color: white; padding: 12px 24px; border-radius: 8px; font-weight: 600; font-size: 1rem; text-decoration: none; transition: background 0.2s, transform 0.2s; }
  .cta-button:hover { background: #c73a24; transform: translateY(-2px); text-decoration: none; }
  .cta-note { font-size: 0.875rem; color: rgba(255,255,255,0.7); margin-top: var(--spacing-md); margin-bottom: 0; }

  .eligibility, .how-it-works { margin-bottom: var(--spacing-xl); }
  .eligibility h2, .how-it-works h2 { font-size: 1.25rem; margin-bottom: var(--spacing-md); }
  .eligibility p, .how-it-works li { color: var(--text-secondary); line-height: 1.7; }
  .how-it-works ol { list-style: decimal; margin-left: var(--spacing-lg); }
  .how-it-works li { margin-bottom: var(--spacing-sm); }

  .content-body { margin-bottom: var(--spacing-xl); line-height: 1.7; }
  .content-body :global(h2) { font-size: 1.25rem; margin-top: var(--spacing-xl); margin-bottom: var(--spacing-md); }
  .content-body :global(h3) { font-size: 1.125rem; margin-top: var(--spacing-lg); margin-bottom: var(--spacing-sm); }
  .content-body :global(p) { color: var(--text-secondary); margin-bottom: var(--spacing-md); }
  .content-body :global(ul), .content-body :global(ol) { color: var(--text-secondary); margin-bottom: var(--spacing-md); padding-left: var(--spacing-lg); }
  .content-body :global(li) { margin-bottom: var(--spacing-sm); }
  .content-body :global(strong) { color: var(--text); }
  .content-body :global(a) { color: var(--primary); }
  .content-body :global(a:hover) { text-decoration: underline; }

  .faq { margin-bottom: var(--spacing-xl); }
  .faq h2 { font-size: 1.25rem; margin-bottom: var(--spacing-lg); }
  .faq-item { margin-bottom: var(--spacing-lg); }
  .faq-item h3 { font-size: 1rem; margin-bottom: var(--spacing-sm); }
  .faq-item p { color: var(--text-secondary); line-height: 1.7; }

  .disclosure { background: #fff3cd; padding: var(--spacing-lg); border-radius: 8px; margin-top: var(--spacing-xl); }
  .disclosure h3 { font-size: 0.875rem; color: #856404; margin-bottom: var(--spacing-sm); text-transform: uppercase; letter-spacing: 0.5px; }
  .disclosure p { color: #856404; font-size: 0.875rem; line-height: 1.6; margin-bottom: 0; }
</style>
