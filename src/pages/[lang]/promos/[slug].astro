---
import MainLayout from '../../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
import { getTranslations, getLocalizedPath } from '../../../i18n/translations';

export async function getStaticPaths() {
  const promos = await getCollection('promos');
  const locales = ['en', 'zh'];
  
  const paths = [];
  for (const promo of promos) {
    for (const locale of locales) {
      paths.push({ params: { lang: locale, slug: promo.slug }, props: { promo } });
    }
  }
  return paths;
}

const { lang, slug } = Astro.params;
const { promo } = Astro.props;
const t = getTranslations(lang);

const isXfinity = slug === 'xfinity-referral';
const title = isXfinity ? (lang === 'en' ? 'Xfinity Referral Program' : 'Xfinity 推荐计划') : promo.data.brand;

const zhSteps = [
  '查看并接受推荐计划条款和条件',
  '从您的 Xfinity 仪表板分享您的推荐链接',
  '朋友有 30 天时间接受邀请并添加符合条件的服务',
  '双方必须保持良好信誉 90 天',
  '符合资格后 4-6 周内通过电子邮件发送奖励'
];

function getStepText(step: string, index: number): string {
  if (lang === 'en') return step;
  return zhSteps[index] || step;
}
---

<MainLayout 
  title={title}
  description={promo.data.eligibility}
  pageType="promo"
  locale={lang}
>
  <div class="promo-page">
    <a href={getLocalizedPath('/promos', lang)} class="back-link">← {t.promos.backToHub}</a>
    
    <div class="brand-badge">{promo.data.brand}</div>
    <h1>{title}</h1>
    
    <div class="reward-box">
      <span class="label">{t.promos.rewardLabel}:</span>
      <span class="value">{promo.data.rewardSummary}</span>
    </div>
    
    <div class="meta">
      <span class="region">{promo.data.region === 'United States' ? t.promos.regionUS : promo.data.region}</span>
      <span class="verified">Verified: {promo.data.lastVerified}</span>
    </div>
    
    <section>
      <h2>{lang === 'en' ? 'Eligibility' : '资格要求'}</h2>
      <p>{promo.data.eligibility}</p>
    </section>
    
    {isXfinity && (
      <>
      <section>
        <h2>{lang === 'en' ? 'How It Works' : '运作方式'}</h2>
        <ol>
          {(promo.data.stepsToRedeem || []).map((step, i) => (
            <li>{getStepText(step, i)}</li>
          ))}
        </ol>
      </section>
      
      <section class="disclosure">
        <p>{promo.data.disclosure}</p>
      </section>
      </>
    )}
  </div>
</MainLayout>

<style>
  .promo-page { max-width: 800px; margin: 0 auto; }
  .back-link { display: inline-block; margin-bottom: var(--spacing-md); color: var(--primary); }
  .brand-badge { display: inline-block; background: var(--primary); color: white; padding: 4px 12px; border-radius: 4px; font-size: 0.875rem; font-weight: 600; margin-bottom: var(--spacing-sm); }
  h1 { margin-bottom: var(--spacing-lg); }
  .reward-box { background: var(--bg-secondary); padding: var(--spacing-lg); border-radius: 8px; margin-bottom: var(--spacing-lg); }
  .reward-box .label { color: var(--text-secondary); margin-right: var(--spacing-sm); }
  .reward-box .value { font-weight: 600; color: var(--primary); font-size: 1.125rem; }
  .meta { display: flex; gap: var(--spacing-md); font-size: 0.875rem; color: var(--text-secondary); margin-bottom: var(--spacing-xl); }
  section { margin-bottom: var(--spacing-xl); }
  section h2 { font-size: 1.25rem; margin-bottom: var(--spacing-md); }
  section p { color: var(--text-secondary); line-height: 1.7; }
  ol { list-style: decimal; margin-left: var(--spacing-lg); color: var(--text-secondary); }
  li { margin-bottom: var(--spacing-sm); line-height: 1.7; }
  .disclosure { background: #fff3cd; padding: var(--spacing-md); border-radius: 4px; font-size: 0.875rem; }
  .disclosure p { color: #856404; }
</style>