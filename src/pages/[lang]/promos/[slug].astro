---
import MainLayout from '../../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
import { getTranslations, getLocalizedPath } from '../../../i18n/index';

export async function getStaticPaths() {
  const promos = await getCollection('promos');
  const locales = ['en', 'zh'];

  const paths = [];
  for (const promo of promos) {
    for (const locale of locales) {
      paths.push({ params: { lang: locale, slug: promo.slug }, props: { promo } });
    }
  }
  return paths;
}

const { lang, slug } = Astro.params;
const { promo } = Astro.props;
const t = getTranslations(lang);
const { Content } = await promo.render();

const isXfinity = slug === 'xfinity-referral';
const referralLink = 'https://referafriend.xfinity.com/ZONGFEI!cbb4bae738!a';

const zhSteps: Record<number, string> = {
  0: '点击本页的推荐链接，前往 Xfinity 官方注册页面',
  1: '选择您的 Xfinity 互联网或移动套餐并完成注册',
  2: '安装并激活您的服务',
  3: '保持服务正常使用 90 天',
  4: '90 天后 4-6 周内通过电子邮件收到 $50 账单抵免'
};

function getStepText(step: string, index: number): string {
  if (lang === 'en') return step;
  return zhSteps[index] || step;
}

const pageTitle = isXfinity
  ? (lang === 'en'
    ? 'Xfinity Refer-a-Friend: Get $50 Off Internet + $50/Line Mobile (2026)'
    : 'Xfinity 推荐好友：互联网立减 $50 + 每条移动线路 $50 (2026)')
  : promo.data.brand;

const pageDescription = promo.data.seo?.description || promo.data.eligibility;

const siteUrl = 'https://xipeter.github.io';
const pagePath = `/${lang}/promos/${slug}/`;
const pageUrl = siteUrl + pagePath;

// Structured data for the offer
const offerJsonLd = isXfinity ? JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Offer",
  "name": "Xfinity Refer-a-Friend Program",
  "description": promo.data.rewardSummary,
  "url": pageUrl,
  "priceCurrency": "USD",
  "availability": "https://schema.org/InStock",
  "seller": {
    "@type": "Organization",
    "name": "Xfinity (Comcast)"
  },
  "validFrom": "2026-01-01",
  "category": "Internet & Mobile Referral"
}) : null;

// FAQ structured data
const faqJsonLd = promo.data.faq && promo.data.faq.length > 0 ? JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": promo.data.faq.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
}) : null;
---

<MainLayout
  title={pageTitle}
  description={pageDescription}
  pageType="promo"
  locale={lang}
>
  {offerJsonLd && <script type="application/ld+json" set:html={offerJsonLd} />}
  {faqJsonLd && <script type="application/ld+json" set:html={faqJsonLd} />}

  <article class="promo-page">
    <a href={getLocalizedPath('/promos', lang)} class="back-link">&larr; {t.promos.backToHub}</a>

    <header class="promo-header">
      <div class="header-top">
        <span class="brand-badge">{promo.data.brand}</span>
        <span class="verified-badge">{t.promos.verifiedLabel} {promo.data.lastVerified}</span>
      </div>
      <h1>{isXfinity ? (lang === 'en' ? 'Get $50 Off Xfinity Internet — Plus $50 Per Mobile Line' : '获得 $50 Xfinity 互联网折扣 — 每条移动线路再减 $50') : promo.data.brand}</h1>
      <p class="hero-subtitle">{lang === 'en'
        ? 'Sign up for Xfinity Internet or Mobile through this referral link and get a $50 bill credit. I get one too — win-win.'
        : '通过此推荐链接注册 Xfinity 互联网或移动服务，即可获得 $50 账单抵免。我也能获得一份——双赢。'}</p>
    </header>

    {isXfinity && (
      <section class="reward-highlight">
        <div class="reward-cards">
          <div class="reward-card">
            <span class="reward-amount">$50</span>
            <span class="reward-label">{lang === 'en' ? 'You Get' : '您获得'}</span>
            <span class="reward-detail">{lang === 'en' ? 'Bill credit for signing up for Internet' : '注册互联网服务获得账单抵免'}</span>
          </div>
          <div class="reward-card">
            <span class="reward-amount">$50</span>
            <span class="reward-label">{lang === 'en' ? 'Per Mobile Line' : '每条移动线路'}</span>
            <span class="reward-detail">{lang === 'en' ? 'Add mobile and save more (up to 5 lines)' : '添加移动服务享更多优惠（最多 5 条线路）'}</span>
          </div>
          <div class="reward-card accent">
            <span class="reward-amount">{lang === 'en' ? 'Up to $300' : '最高 $300'}</span>
            <span class="reward-label">{lang === 'en' ? 'Your Total Savings' : '您的总节省金额'}</span>
            <span class="reward-detail">{lang === 'en' ? 'Internet + mobile lines combined' : '互联网 + 移动线路合计'}</span>
          </div>
        </div>
      </section>
    )}

    {!isXfinity && (
      <div class="reward-box">
        <span class="label">{t.promos.rewardLabel}:</span>
        <span class="value">{promo.data.rewardSummary}</span>
      </div>
    )}

    <section class="how-it-works">
      <h2>{isXfinity ? (lang === 'en' ? 'How to Get Your $50 Credit' : '如何获得您的 $50 抵免') : t.promos.howItWorksTitle}</h2>
      <div class="steps">
        {(promo.data.stepsToRedeem || []).map((step: string, i: number) => (
          <div class="step">
            <span class="step-number">{i + 1}</span>
            <p>{getStepText(step, i)}</p>
          </div>
        ))}
      </div>
    </section>

    {isXfinity && (
      <section class="referral-cta">
        <h2>{lang === 'en' ? 'Ready to Save?' : '准备好省钱了吗？'}</h2>
        <p>{t.promos.referralCtaText}</p>
        <a href={referralLink} class="cta-button" target="_blank" rel="noopener noreferrer">
          {t.promos.referralCtaButton}
        </a>
        <p class="cta-note">{t.promos.referralCtaNote}</p>
      </section>
    )}

    <section class="eligibility">
      <h2>{isXfinity ? (lang === 'en' ? 'Are You Eligible?' : '您符合条件吗？') : t.promos.eligibilityTitle}</h2>
      <p>{promo.data.eligibility}</p>
    </section>

    <div class="content-body">
      <Content />
    </div>

    {promo.data.faq && promo.data.faq.length > 0 && (
      <section class="faq">
        <h2>{lang === 'en' ? 'Frequently Asked Questions' : '常见问题'}</h2>
        {promo.data.faq.map(item => (
          <details class="faq-item">
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </section>
    )}

    {isXfinity && (
      <section class="referral-cta bottom-cta">
        <h2>{lang === 'en' ? 'Get Your $50+ Credit Now' : '立即获取 $50+ 账单抵免'}</h2>
        <a href={referralLink} class="cta-button" target="_blank" rel="noopener noreferrer">
          {t.promos.referralCtaButton}
        </a>
      </section>
    )}

    <section class="disclosure">
      <h3>{t.promos.disclosureLabel}</h3>
      <p>{t.promos.disclosureText}</p>
    </section>
  </article>
</MainLayout>

<style>
  .promo-page { max-width: 800px; margin: 0 auto; }
  .back-link { display: inline-block; margin-bottom: var(--spacing-md); color: var(--primary); }

  /* Header */
  .promo-header { margin-bottom: var(--spacing-xl); }
  .header-top { display: flex; align-items: center; gap: var(--spacing-md); margin-bottom: var(--spacing-md); flex-wrap: wrap; }
  .brand-badge { display: inline-block; background: var(--primary); color: white; padding: 4px 12px; border-radius: 4px; font-size: 0.875rem; font-weight: 600; }
  .verified-badge { display: inline-flex; align-items: center; gap: 4px; background: #e8f5e9; color: #2e7d32; padding: 4px 12px; border-radius: 4px; font-size: 0.75rem; font-weight: 600; }
  .promo-header h1 { font-size: 2rem; margin-bottom: var(--spacing-sm); }
  .hero-subtitle { font-size: 1.125rem; color: var(--text-secondary); line-height: 1.6; }

  /* Reward highlight cards */
  .reward-highlight { margin-bottom: var(--spacing-xl); }
  .reward-cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: var(--spacing-md); }
  .reward-card { background: var(--bg-secondary); border: 1px solid var(--border); border-radius: 12px; padding: var(--spacing-lg); text-align: center; display: flex; flex-direction: column; gap: 4px; }
  .reward-card.accent { background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%); border-color: transparent; color: white; }
  .reward-amount { font-size: 2rem; font-weight: 700; color: var(--primary); line-height: 1.2; }
  .reward-card.accent .reward-amount { color: #4fc3f7; }
  .reward-label { font-size: 0.9375rem; font-weight: 600; }
  .reward-detail { font-size: 0.8125rem; color: var(--text-secondary); }
  .reward-card.accent .reward-detail { color: rgba(255,255,255,0.7); }

  /* Generic reward box (non-Xfinity) */
  .reward-box { background: var(--bg-secondary); padding: var(--spacing-lg); border-radius: 8px; margin-bottom: var(--spacing-xl); }
  .reward-box .label { color: var(--text-secondary); margin-right: var(--spacing-sm); }
  .reward-box .value { font-weight: 600; color: var(--primary); font-size: 1.125rem; }

  /* How it works - numbered steps */
  .how-it-works { margin-bottom: var(--spacing-xl); }
  .how-it-works h2 { font-size: 1.25rem; margin-bottom: var(--spacing-lg); }
  .steps { display: flex; flex-direction: column; gap: var(--spacing-md); }
  .step { display: flex; gap: var(--spacing-md); align-items: flex-start; }
  .step-number { display: flex; align-items: center; justify-content: center; width: 32px; height: 32px; min-width: 32px; background: var(--primary); color: white; border-radius: 50%; font-weight: 700; font-size: 0.875rem; }
  .step p { color: var(--text-secondary); line-height: 1.7; margin: 0; padding-top: 4px; }

  /* CTA sections */
  .referral-cta { background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%); color: white; padding: var(--spacing-xl); border-radius: 12px; margin-bottom: var(--spacing-xl); text-align: center; }
  .referral-cta h2 { color: white; margin-bottom: var(--spacing-md); font-size: 1.5rem; }
  .referral-cta p { color: rgba(255,255,255,0.9); margin-bottom: var(--spacing-lg); line-height: 1.6; }
  .cta-button { display: inline-block; background: #e1402a; color: white; padding: 14px 32px; border-radius: 8px; font-weight: 600; font-size: 1.0625rem; text-decoration: none; transition: background 0.2s, transform 0.2s; box-shadow: 0 4px 12px rgba(225, 64, 42, 0.3); }
  .cta-button:hover { background: #c73a24; transform: translateY(-2px); text-decoration: none; box-shadow: 0 6px 16px rgba(225, 64, 42, 0.4); }
  .cta-note { font-size: 0.875rem; color: rgba(255,255,255,0.7); margin-top: var(--spacing-md); margin-bottom: 0; }
  .bottom-cta { margin-top: var(--spacing-xl); }
  .bottom-cta p { display: none; }

  /* Eligibility */
  .eligibility { margin-bottom: var(--spacing-xl); }
  .eligibility h2 { font-size: 1.25rem; margin-bottom: var(--spacing-md); }
  .eligibility p { color: var(--text-secondary); line-height: 1.7; }

  /* Content body */
  .content-body { margin-bottom: var(--spacing-xl); line-height: 1.7; }
  .content-body :global(h2) { font-size: 1.25rem; margin-top: var(--spacing-xl); margin-bottom: var(--spacing-md); }
  .content-body :global(h3) { font-size: 1.125rem; margin-top: var(--spacing-lg); margin-bottom: var(--spacing-sm); }
  .content-body :global(p) { color: var(--text-secondary); margin-bottom: var(--spacing-md); }
  .content-body :global(ul), .content-body :global(ol) { color: var(--text-secondary); margin-bottom: var(--spacing-md); padding-left: var(--spacing-lg); }
  .content-body :global(li) { margin-bottom: var(--spacing-sm); }
  .content-body :global(strong) { color: var(--text); }
  .content-body :global(a) { color: var(--primary); }
  .content-body :global(a:hover) { text-decoration: underline; }

  /* FAQ with collapsible details */
  .faq { margin-bottom: var(--spacing-xl); }
  .faq h2 { font-size: 1.25rem; margin-bottom: var(--spacing-lg); }
  .faq-item { border: 1px solid var(--border); border-radius: 8px; margin-bottom: var(--spacing-sm); overflow: hidden; }
  .faq-item summary { padding: var(--spacing-md) var(--spacing-lg); font-weight: 600; cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after { content: '+'; font-size: 1.25rem; color: var(--text-secondary); transition: transform 0.2s; }
  .faq-item[open] summary::after { content: '-'; }
  .faq-item[open] summary { border-bottom: 1px solid var(--border); }
  .faq-item p { padding: var(--spacing-md) var(--spacing-lg); color: var(--text-secondary); line-height: 1.7; margin: 0; }

  /* Disclosure */
  .disclosure { background: #fff3cd; padding: var(--spacing-lg); border-radius: 8px; margin-top: var(--spacing-xl); }
  .disclosure h3 { font-size: 0.875rem; color: #856404; margin-bottom: var(--spacing-sm); text-transform: uppercase; letter-spacing: 0.5px; }
  .disclosure p { color: #856404; font-size: 0.875rem; line-height: 1.6; margin-bottom: 0; }

  @media (max-width: 600px) {
    .reward-cards { grid-template-columns: 1fr; }
    .promo-header h1 { font-size: 1.5rem; }
    .reward-amount { font-size: 1.75rem; }
  }
</style>
