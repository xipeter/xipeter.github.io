---
import MainLayout from '../../layouts/MainLayout.astro';
import { getTranslations } from '../../i18n/index';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'zh' } }
  ];
}

const { lang } = Astro.params;
const t = getTranslations(lang);
---

<MainLayout
  title={t.terms.title}
  description={t.terms.intro}
  pageType="terms"
  showAds={false}
  locale={lang}
>
  <article class="policy-page">
    <h1>{t.terms.title}</h1>
    <p class="last-updated">{t.terms.lastUpdated}</p>

    <section>
      <h2>{t.terms.acceptTitle}</h2>
      <p>{t.terms.acceptText}</p>
    </section>

    <section>
      <h2>{t.terms.useTitle}</h2>
      <p>{t.terms.useText}</p>
    </section>

    <section>
      <h2>{t.terms.responsibilityTitle}</h2>
      <p>{t.terms.responsibilityText}</p>
    </section>

    <section>
      <h2>{t.terms.intellectualPropertyTitle}</h2>
      <p>{t.terms.intellectualPropertyText}</p>
    </section>

    <section>
      <h2>{t.terms.thirdPartyLinksTitle}</h2>
      <p>{t.terms.thirdPartyLinksText}</p>
    </section>

    <section>
      <h2>{t.terms.advertisingTitle}</h2>
      <p>{t.terms.advertisingText}</p>
    </section>

    <section>
      <h2>{t.terms.disclaimerTitle}</h2>
      <p>{t.terms.disclaimerText}</p>
    </section>

    <section>
      <h2>{t.terms.changesTitle}</h2>
      <p>{t.terms.changesText}</p>
    </section>
  </article>
</MainLayout>

<style>
  .policy-page { max-width: 800px; margin: 0 auto; }
  h1 { margin-bottom: var(--spacing-sm); }
  .last-updated { color: var(--text-secondary); margin-bottom: var(--spacing-xl); }
  section { margin-bottom: var(--spacing-xl); }
  section h2 { font-size: 1.5rem; margin-bottom: var(--spacing-md); }
  section p { color: var(--text-secondary); line-height: 1.7; }
</style>
