---
import MainLayout from '../../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
import { getTranslations, getLocalizedPath } from '../../../i18n/index';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  const baseArticles = articles.filter(a => !a.slug.endsWith('-zh'));

  const paths = [];
  for (const article of baseArticles) {
    const zhVariant = articles.find(a => a.slug === `${article.slug}-zh`);

    paths.push({
      params: { lang: 'en', slug: article.slug },
      props: { article, hasZh: !!zhVariant }
    });
    paths.push({
      params: { lang: 'zh', slug: article.slug },
      props: { article: zhVariant ?? article, hasZh: !!zhVariant }
    });
  }
  return paths;
}

const { lang } = Astro.params;
const { article, hasZh } = Astro.props;
const t = getTranslations(lang);
const { Content } = await article.render();

const showFallbackNotice = lang === 'zh' && !hasZh;
---

<MainLayout
  title={article.data.title}
  description={article.data.excerpt}
  pageType="article"
  locale={lang}
>
  <article class="article-page">
    <a href={getLocalizedPath('/articles', lang)} class="back-link">&larr; {t.articles.backToHub}</a>

    <header>
      <h1>{article.data.title}</h1>
      <div class="meta">
        <span class="category-tag">{article.data.category}</span>
        <span class="date">{new Date(article.data.publishedAt).toLocaleDateString(lang === 'zh' ? 'zh-CN' : 'en-US')}</span>
        <span class="reading-time">{article.data.readingTime} {t.common.minRead}</span>
      </div>
    </header>

    {showFallbackNotice && (
      <div class="translation-notice">
        <p>{t.articles.translationPending}</p>
      </div>
    )}

    <div class="content">
      <Content />
    </div>
  </article>
</MainLayout>

<style>
  .article-page { max-width: 800px; margin: 0 auto; }
  .back-link { display: inline-block; margin-bottom: var(--spacing-md); color: var(--primary); }
  header { margin-bottom: var(--spacing-xl); }
  h1 { margin-bottom: var(--spacing-md); }
  .meta { display: flex; gap: var(--spacing-md); font-size: 0.875rem; color: var(--text-secondary); flex-wrap: wrap; }
  .category-tag { background: var(--bg-secondary); padding: 2px 8px; border-radius: 4px; }
  .translation-notice { background: #fff3cd; border: 1px solid #ffc107; border-radius: 8px; padding: var(--spacing-md) var(--spacing-lg); margin-bottom: var(--spacing-xl); }
  .translation-notice p { color: #856404; margin: 0; font-size: 0.9375rem; }
  .content { line-height: 1.7; }
  .content :global(h2) { margin-top: var(--spacing-xl); margin-bottom: var(--spacing-md); }
  .content :global(h3) { margin-top: var(--spacing-lg); margin-bottom: var(--spacing-sm); }
  .content :global(p) { margin-bottom: var(--spacing-md); color: var(--text-secondary); }
  .content :global(ul), .content :global(ol) { margin-bottom: var(--spacing-md); padding-left: var(--spacing-lg); color: var(--text-secondary); }
  .content :global(li) { margin-bottom: var(--spacing-sm); }
  .content :global(code) { background: var(--bg-secondary); padding: 2px 6px; border-radius: 4px; font-size: 0.875rem; }
  .content :global(pre) { background: var(--bg-secondary); padding: var(--spacing-md); border-radius: 8px; overflow-x: auto; margin-bottom: var(--spacing-md); }
  .content :global(pre code) { background: none; padding: 0; }
  .content :global(blockquote) { border-left: 4px solid var(--primary); padding-left: var(--spacing-lg); margin: var(--spacing-lg) 0; color: var(--text-secondary); font-style: italic; }
  .content :global(a) { color: var(--primary); }
  .content :global(a:hover) { text-decoration: underline; }
  .content :global(img) { max-width: 100%; height: auto; border-radius: 8px; margin: var(--spacing-md) 0; }
  .content :global(table) { width: 100%; border-collapse: collapse; margin-bottom: var(--spacing-md); }
  .content :global(th), .content :global(td) { border: 1px solid var(--border); padding: var(--spacing-sm) var(--spacing-md); text-align: left; }
  .content :global(th) { background: var(--bg-secondary); font-weight: 600; }
</style>
