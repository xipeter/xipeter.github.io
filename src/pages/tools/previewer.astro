---
import MainLayout from '../../layouts/MainLayout.astro';
import { StoreProvider } from '../../contexts/StoreContext';
import { I18nProvider } from '../../contexts/I18nContext';
import App from '../../App';
---

<MainLayout 
  title="Content Previewer - Markdown JSON XML Diff Tool" 
  description="Preview and validate Markdown, JSON, and XML content in your browser. Compare differences between two versions with the built-in diff viewer."
  pageType="tool"
>
  <StoreProvider client:load>
    <I18nProvider client:load>
      <App client:load />
    </I18nProvider>
  </StoreProvider>
</MainLayout>