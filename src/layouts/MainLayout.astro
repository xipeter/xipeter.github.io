---
import BaseLayout from './BaseLayout.astro';
import type { PageType } from '../utils/adEligibility';
import { getAdEligibility } from '../utils/adEligibility';
import { getTranslations, getAlternateLocale, getLocalizedPath } from '../i18n/translations';

interface Props {
  title: string;
  description?: string;
  pageType: PageType;
  showAds?: boolean;
  noindex?: boolean;
  locale?: string;
}

const { title, description, pageType, showAds = true, noindex = false, locale = 'en' } = Astro.props;
const adConfig = getAdEligibility(pageType);
const t = getTranslations(locale);
const alternateLocale = getAlternateLocale(locale);
---

<BaseLayout 
  title={title} 
  description={description}
  pageType={pageType}
  noindex={noindex}
  locale={locale}
>
  <!-- Header -->
  <header class="site-header">
    <div class="container header-inner">
      <a href={getLocalizedPath('/', locale)} class="logo">TechHub</a>
      <nav class="main-nav">
        <a href={getLocalizedPath('/articles', locale)}>{t.nav.articles}</a>
        <a href={getLocalizedPath('/tools', locale)}>{t.nav.tools}</a>
        <a href={getLocalizedPath('/promos', locale)}>{t.nav.promos}</a>
      </nav>
      <div class="lang-switch">
        <a href={getLocalizedPath('/', alternateLocale)} class={locale === 'en' ? '' : ''}>
          {alternateLocale === 'en' ? 'EN' : '中'}
        </a>
      </div>
    </div>
  </header>

  <!-- Ad Slot - Top -->
  {showAds && adConfig.eligible && adConfig.slotPositions.includes('top') && (
    <div class="container">
      <div class="ad-slot" id="adsense-top">
        <span>Advertisement</span>
      </div>
    </div>
  )}

  <!-- Main Content -->
  <main class="main-content">
    <div class="container">
      <slot />
    </div>
  </main>

  <!-- Ad Slot - Bottom -->
  {showAds && adConfig.eligible && adConfig.slotPositions.includes('bottom') && (
    <div class="container">
      <div class="ad-slot" id="adsense-bottom">
        <span>Advertisement</span>
      </div>
    </div>
  )}

  <!-- Footer -->
  <footer class="site-footer">
    <div class="container">
      <div class="footer-links">
        <div class="footer-section">
          <h4>{t.nav.home}</h4>
          <a href={getLocalizedPath('/articles', locale)}>{t.nav.articles}</a>
          <a href={getLocalizedPath('/tools', locale)}>{t.nav.tools}</a>
          <a href={getLocalizedPath('/promos', locale)}>{t.nav.promos}</a>
        </div>
        <div class="footer-section">
          <h4>{t.nav.about}</h4>
          <a href={getLocalizedPath('/contact', locale)}>{t.nav.contact}</a>
        </div>
        <div class="footer-section">
          <h4>Legal</h4>
          <a href={getLocalizedPath('/privacy-policy', locale)}>{t.privacy.title}</a>
          <a href={getLocalizedPath('/terms', locale)}>{t.terms.title}</a>
          <a href={getLocalizedPath('/editorial-policy', locale)}>{t.editorial.title}</a>
          <a href={getLocalizedPath('/affiliate-disclosure', locale)}>{t.affiliate.title}</a>
        </div>
      </div>
      <p class="copyright">&copy; {new Date().getFullYear()} TechHub. All rights reserved.</p>
    </div>
  </footer>
</BaseLayout>

<style>
  .site-header {
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    padding: var(--spacing-md) 0;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--primary);
    text-decoration: none;
  }

  .main-nav {
    display: flex;
    gap: var(--spacing-lg);
  }

  .main-nav a {
    color: var(--text);
    font-weight: 500;
    padding: var(--spacing-sm) 0;
    border-bottom: 2px solid transparent;
    transition: border-color 0.2s;
  }

  .main-nav a:hover {
    text-decoration: none;
    border-bottom-color: var(--primary);
  }

  .main-content {
    flex: 1;
    padding: var(--spacing-xl) 0;
    min-height: 60vh;
  }

  .site-footer {
    background: var(--bg-secondary);
    padding: var(--spacing-xl) 0;
    margin-top: auto;
  }

  .footer-links {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: var(--spacing-lg);
    margin-bottom: var(--spacing-lg);
  }

  .footer-section h4 {
    font-size: 0.875rem;
    font-weight: 600;
    margin-bottom: var(--spacing-sm);
    color: var(--text);
  }

  .footer-section a {
    display: block;
    color: var(--text-secondary);
    font-size: 0.875rem;
    margin-bottom: var(--spacing-sm);
  }

  .copyright {
    text-align: center;
    color: var(--text-secondary);
    font-size: 0.875rem;
    padding-top: var(--spacing-lg);
    border-top: 1px solid var(--border);
  }

  @media (max-width: 768px) {
    .header-inner {
      flex-direction: column;
      gap: var(--spacing-md);
    }

    .main-nav {
      flex-wrap: wrap;
      justify-content: center;
      gap: var(--spacing-md);
    }
  }

  .lang-switch {
    margin-left: var(--spacing-md);
  }

  .lang-switch a {
    padding: 4px 8px;
    background: var(--bg-secondary);
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-secondary);
  }

  .lang-switch a:hover {
    background: var(--primary);
    color: white;
    text-decoration: none;
  }
</style>