---
import type { PageType } from '../utils/adEligibility';

interface Props {
  title: string;
  description?: string;
  pageType: PageType;
  canonical?: string;
  noindex?: boolean;
  locale?: string;
}

const {
  title,
  description = 'A tech utility and content hub featuring developer tools, technical articles, curated tech news, and verified promotions.',
  pageType,
  canonical,
  noindex = false,
  locale = 'en'
} = Astro.props;

const fullTitle = title === 'TechHub' ? title : `${title} | TechHub`;
const siteUrl = 'https://xipeter.github.io';

const rawPath = Astro.url.pathname;

let pathWithoutLocale = rawPath
  .replace(/^\/en\/?$/, '/')
  .replace(/^\/zh\/?$/, '/')
  .replace(/^\/en\//, '/')
  .replace(/^\/zh\//, '/')
  .replace(/\/$/, '');

const enPath = pathWithoutLocale === '/' || pathWithoutLocale === ''
  ? '/en/'
  : `/en${pathWithoutLocale}/`;
const zhPath = pathWithoutLocale === '/' || pathWithoutLocale === ''
  ? '/zh/'
  : `/zh${pathWithoutLocale}/`;

const enUrl = siteUrl + enPath;
const zhUrl = siteUrl + zhPath;
const canonicalUrl = locale === 'en' ? enUrl : zhUrl;
---

<!DOCTYPE html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, follow" />}

    <link rel="canonical" href={canonicalUrl} />

    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="zh" href={zhUrl} />
    <link rel="alternate" hreflang="x-default" href={siteUrl + '/en/'} />

    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3992506272308291" crossorigin="anonymous"></script>

    <link rel="icon" type="image/svg+xml" href="/vite.svg" />
    <meta name="theme-color" content="#1976d2" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --primary: #1976d2;
    --primary-dark: #1565c0;
    --text: #333;
    --text-secondary: #666;
    --bg: #fff;
    --bg-secondary: #f5f5f5;
    --border: #e0e0e0;
    --spacing-sm: 0.5rem;
    --spacing-md: 1rem;
    --spacing-lg: 2rem;
    --spacing-xl: 3rem;
    --max-width: 1200px;
    --font-sans: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    font-family: var(--font-sans);
    line-height: 1.6;
    color: var(--text);
    background: var(--bg);
  }

  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  a {
    color: var(--primary);
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  h1, h2, h3, h4, h5, h6 {
    line-height: 1.3;
    margin-bottom: var(--spacing-md);
  }

  h1 { font-size: 2.5rem; }
  h2 { font-size: 2rem; }
  h3 { font-size: 1.5rem; }

  p {
    margin-bottom: var(--spacing-md);
  }

  img {
    max-width: 100%;
    height: auto;
  }

  .container {
    width: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--spacing-md);
  }

  .ad-slot {
    min-height: 100px;
    background: var(--bg-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: var(--spacing-lg) 0;
    border: 1px dashed var(--border);
    color: var(--text-secondary);
    font-size: 0.875rem;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --text: #e0e0e0;
      --text-secondary: #aaa;
      --bg: #1a1a1a;
      --bg-secondary: #2a2a2a;
      --border: #444;
    }
  }
</style>
